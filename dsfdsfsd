local function createButton(text, yPos, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 32)
    btn.Position = UDim2.new(0.075, 0, yPos, 0)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 50, 60)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = MainFrame
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- Переменные состояний
local xrayActive = false
local espActive = false
local espHighlights = {}

-- Очистка подсветок
local function clearHighlights()
    for _, h in pairs(espHighlights) do
        pcall(function() h:Destroy() end)
    end
    espHighlights = {}
end

-- Подсветка роли
local function highlightRole(roleName, color, duration)
    clearHighlights()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr:FindFirstChild("role") and plr.role.Value == roleName then
            if plr.Character then
                local hl = Instance.new("Highlight")
                hl.Parent = plr.Character
                hl.FillColor = color
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                hl.Enabled = true
                table.insert(espHighlights, hl)
            end
        end
    end
    if duration then
        task.delay(duration, clearHighlights)
    end
end

