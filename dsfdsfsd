    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local pos = input.Position.X
        local start = slider.AbsolutePosition.X
        local size = slider.AbsoluteSize.X
        
        if size > 0 then
            local percent = math.clamp((pos - start) / size, 0, 1)
            speed = math.floor(10 + percent * 90)
            
            fill.Size = UDim2.new(percent, 0, 1, 0)
            dot.Position = UDim2.new(percent, -8, 0.5, -8)
            speedLabel.Text = "⚡ Speed: " .. speed
        end
    end
end)

-- ФУНКЦИИ ПОЛЕТА
local function startFly()
    if bodyVel then bodyVel:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    
    bodyVel = Instance.new("BodyVelocity")
    bodyVel.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVel.Parent = root
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.P = 1e5
    bodyGyro.Parent = root
    
    hum.PlatformStand = true
end

local function stopFly()
    if bodyVel then bodyVel:Destroy() bodyVel = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    hum.PlatformStand = false
end

local function updateFly()
    if not flying then return end
    if not bodyVel or not bodyGyro then
        startFly()
    end
    
    local cam = workspace.CurrentCamera
    if not cam then return end
    
    local forward = cam.CFrame.LookVector
    local right = cam.CFrame.RightVector
    local up = cam.CFrame.UpVector
    
    local move = Vector3.new(0, 0, 0)
    
    if userInputService:IsKeyDown(Enum.KeyCode.W) then move = move + forward end
    if userInputService:IsKeyDown(Enum.KeyCode.S) then move = move - forward end
    if userInputService:IsKeyDown(Enum.KeyCode.A) then move = move - right end
    if userInputService:IsKeyDown(Enum.KeyCode.D) then move = move + right end
    if userInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + up end
    if userInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - up end
    
    if move.Magnitude > 0 then
        move = move.Unit * speed
    end
    
    bodyVel.Velocity = move
    
    if move.Magnitude > 0.1 then
        bodyGyro.CFrame = CFrame.new(root.Position, root.Position + move)
    else
        bodyGyro.CFrame = cam.CFrame
    end
end

function toggleFly()
    flying = not flying
    
    if flying then
        startFly()
        if flyConn then flyConn:Disconnect() end
        flyConn = runService.RenderStepped:Connect(updateFly)
        flyBtn.Text = "✈ FLY: ON"
        flyBtn.BackgroundColor3 = Color3.fromRGB(60, 200, 100)
    else
        stopFly()
        if flyConn then flyConn:Disconnect() flyConn = nil end
        flyBtn.Text = "✈ FLY: OFF"
        flyBtn.BackgroundColor3 = Color3.fromRGB(30, 80, 150)
    end
end

-- ФУНКЦИИ NOCLIP
function toggleNoclip()
    noclip = not noclip
    
    if noclip then
        -- Отключаем коллизии
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
        
        -- Постоянно обновляем
        if noclipConn then noclipConn:Disconnect() end
        noclipConn = runService.RenderStepped:Connect(function()
            if not noclip then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide ~= false then
                    part.CanCollide = false
                end
            end
        end)
        
        noclipBtn.Text = "👻 NOCLIP: ON"
        noclipBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 100)
    else
        -- Включаем коллизии
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        
        if noclipConn then noclipConn:Disconnect() noclipConn = nil end
        noclipBtn.Text = "👻 NOCLIP: OFF"
        noclipBtn.BackgroundColor3 = Color3.fromRGB(150, 30, 80)
    end
end

-- КНОПКИ
flyBtn.MouseButton1Click:Connect(toggleFly)
noclipBtn.MouseButton1Click:Connect(toggleNoclip)

