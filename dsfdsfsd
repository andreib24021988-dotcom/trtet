    for _, v in pairs(game.Players:GetPlayers()) do table.insert(list, v.Name) end
    TrollTab:RefreshDropdown(list)
end)
TrollTab:CreateButton("Force Jump", function()
    if trollTarget and game.Players[trollTarget].Character then
        game.Players[trollTarget].Character.Humanoid.Jump = true
    end
end)
TrollTab:CreateButton("Rocket Fling", function()
    if trollTarget and game.Players[trollTarget].Character then
        game.Players[trollTarget].Character.HumanoidRootPart.Velocity = Vector3.new(0, 1000, 0)
    end
end)
TrollTab:CreateButton("Slam", function()
    if trollTarget and game.Players[trollTarget].Character then
        game.Players[trollTarget].Character.HumanoidRootPart.Velocity = Vector3.new(0, -500, 0)
    end
end)

-- Вспомогательные функции (заглушки)
function getMurderer()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("MurdererTag") then return p.Character end
    end
end

function getSheriff()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character and p.Character:FindFirstChild("SheriffTag") then return p.Character end
    end
end

