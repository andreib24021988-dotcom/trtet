-- Thunder Style UI
-- Roblox Studio LocalScript

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer

-- ScreenGui
local gui = Instance.new("ScreenGui")
gui.Name = "ThunderHubUI"
gui.Parent = player.PlayerGui
gui.ResetOnSpawn = false


-- Main Window
local main = Instance.new("Frame")
main.Size = UDim2.new(0,600,0,380)
main.Position = UDim2.new(0.5,-300,0.5,-190)
main.BackgroundColor3 = Color3.fromRGB(18,18,22)
main.BorderSizePixel = 0
main.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0,10)
corner.Parent = main


-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,35)
title.BackgroundTransparency = 1
title.Text = "Thunder Hub | Custom"
title.TextColor3 = Color3.fromRGB(255,255,255)
title.Font = Enum.Font.GothamBold
title.TextSize = 16
title.Parent = main


-- Tabs
local tabs = Instance.new("Frame")
tabs.Size = UDim2.new(0,150,1,-35)
tabs.Position = UDim2.new(0,0,0,35)
tabs.BackgroundColor3 = Color3.fromRGB(14,14,18)
tabs.Parent = main


local content = Instance.new("Frame")
content.Size = UDim2.new(1,-160,1,-45)
content.Position = UDim2.new(0,160,0,45)
content.BackgroundTransparency = 1
content.Parent = main



local function createButton(text,y,callback)

	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0.9,0,0,35)
	b.Position = UDim2.new(0.05,0,0,y)
	b.BackgroundColor3 = Color3.fromRGB(35,35,42)
	b.Text = text
	b.TextColor3 = Color3.new(1,1,1)
	b.Font = Enum.Font.Gotham
	b.TextSize = 14
	b.Parent = content

	local c = Instance.new("UICorner")
	c.Parent=b

	b.MouseButton1Click:Connect(callback)

	return b
end


local function toggle(text,y)

	local state=false

	local b=createButton(text.." : OFF",y,function()

		state=not state

		if state then
			b.Text=text.." : ON"
			b.BackgroundColor3=Color3.fromRGB(0,170,100)
		else
			b.Text=text.." : OFF"
			b.BackgroundColor3=Color3.fromRGB(35,35,42)
		end

	end)

end


-- Left menu

local categories={
	"Character",
	"Visual",
	"Players",
	"Teleport",
	"Settings"
}


for i,v in ipairs(categories) do

	local b=Instance.new("TextButton")

	b.Size=UDim2.new(0.9,0,0,35)
	b.Position=UDim2.new(0.05,0,0,(i-1)*45+10)

	b.Text=v
	b.BackgroundColor3=Color3.fromRGB(35,35,42)
	b.TextColor3=Color3.new(1,1,1)

	b.Font=Enum.Font.Gotham
	b.TextSize=14

	b.Parent=tabs


	local c=Instance.new("UICorner")
	c.Parent=b

end



-- Example options

