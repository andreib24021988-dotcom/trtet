--[[
    РАБОЧИЙ FLY + NOCLIP ДЛЯ ROBLOX
    Управление:
    F = Вкл/Выкл полёт
    V = Вкл/Выкл noclip
    Пробел = Вверх (в полёте)
    Shift = Вниз (в полёте)
    WASD = Движение
]]

-- Проверка, что скрипт выполняется в локальном игроке
local player = game.Players.LocalPlayer
if not player then return end

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Переменные состояния
local flying = false
local noclipEnabled = false
local speed = 50
local bodyVelocity = nil
local bodyGyro = nil

-- Функция для создания Velocity и Gyro
local function createFlyObjects()
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.P = 1e5
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
end

-- Удаление объектов полёта
local function destroyFlyObjects()
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

-- Функция полёта (вызывается каждый кадр)
local function flyUpdate()
    if not flying then return end
    if not bodyVelocity or not bodyGyro then
        createFlyObjects()
    end
    
    -- Получаем направление камеры
    local camera = workspace.CurrentCamera
    local forward = camera.CFrame.LookVector
    local right = camera.CFrame.RightVector
    local up = camera.CFrame.UpVector
    
    -- Ввод с клавиатуры
    local moveDirection = Vector3.new(0, 0, 0)
    
    -- WASD
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + forward
    end
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - forward
    end
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - right
    end
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + right
    end
    
    -- Вверх/Вниз
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + up
    end
    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftShift) then
        moveDirection = moveDirection - up
    end
    
    -- Нормализуем и применяем скорость
    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit * speed
    end
    
    -- Обновляем Velocity
    bodyVelocity.Velocity = moveDirection
    
    -- Поворачиваем персонажа в сторону движения
    if moveDirection.Magnitude > 0.1 then
        bodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + moveDirection)
    else
        bodyGyro.CFrame = camera.CFrame * CFrame.new(0, 0, -1)
    end
end

-- Включение полёта
local function startFly()
    if flying then return end
    flying = true
    
    -- Отключаем гравитацию
    humanoid.PlatformStand = true
    
    -- Создаём объекты для полёта
    createFlyObjects()
    
    -- Запускаем обновление
    game:GetService("RunService").RenderStepped:Connect(flyUpdate)
    
    print("🛫 Полёт ВКЛЮЧЁН")
end

-- Выключение полёта
local function stopFly()
    if not flying then return end
    flying = false
    
    -- Включаем гравитацию обратно
    humanoid.PlatformStand = false
    
    -- Удаляем объекты
    destroyFlyObjects()
    
    print("🛬 Полёт ВЫКЛЮЧЁН")
end

-- Переключение полёта
local function toggleFly()
    if flying then
        stopFly()
    else
        startFly()
    end
end

-- Noclip функция
local function toggleNoclip()
    noclipEnabled = not noclipEnabled
    
    if noclipEnabled then
        -- Включаем noclip
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
        
        -- Отключаем коллизии для новых частей
        character.DescendantAdded:Connect(function(part)
            if noclipEnabled and part:IsA("BasePart") then
                part.CanCollide = false
            end
        end)
        
        print("👻 Noclip ВКЛЮЧЁН")
    else
        -- Выключаем noclip
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        print("🔒 Noclip ВЫКЛЮЧЁН")
    end
end

-- Обработка нажатий клавиш
game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    -- F - полёт
    if input.KeyCode == Enum.KeyCode.F then
        toggleFly()
    end
    
    -- V - noclip
    if input.KeyCode == Enum.KeyCode.V then
        toggleNoclip()
    end
end)

-- Очистка при смерти персонажа
player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    rootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    
    -- Сбрасываем состояние
    if flying then
        stopFly()
    end
    
    -- Если noclip был включён, отключаем
    if noclipEnabled then
        noclipEnabled = false
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end)

