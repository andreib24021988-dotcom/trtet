-- Вкладка TROLL
local TrollTab = Window:CreateTab("Troll")
TrollTab:CreateDropdown("Target Player", {}, function(plr) trollTarget = plr end)
TrollTab:CreateButton("Refresh Player List", function() -- обновить список для троллинга
