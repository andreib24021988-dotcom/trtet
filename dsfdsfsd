-- ФУНКЦИИ ПОЛЁТА
local function createFlyObjects()
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.P = 1e5
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
end

local function destroyFlyObjects()
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

local function flyUpdate()
    if not flying then return end
    if not bodyVelocity or not bodyGyro then
        createFlyObjects()
    end
    
    local camera = workspace.CurrentCamera
    local forward = camera.CFrame.LookVector
    local right = camera.CFrame.RightVector
    local up = camera.CFrame.UpVector
    
    local moveDirection = Vector3.new(0, 0, 0)
    
    if userInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDirection = moveDirection + forward
    end
    if userInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDirection = moveDirection - forward
    end
    if userInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDirection = moveDirection - right
    end
    if userInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDirection = moveDirection + right
    end
    if userInputService:IsKeyDown(Enum.KeyCode.Space) then
        moveDirection = moveDirection + up
    end
    if userInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        moveDirection = moveDirection - up
    end
    
    if moveDirection.Magnitude > 0 then
        moveDirection = moveDirection.Unit * speed
    end
    
    bodyVelocity.Velocity = moveDirection
    
    if moveDirection.Magnitude > 0.1 then
        bodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + moveDirection)
    else
        bodyGyro.CFrame = camera.CFrame
    end
end

function toggleFly()
    flying = not flying
    
    if flying then
        humanoid.PlatformStand = true
        createFlyObjects()
        if flyConnection then flyConnection:Disconnect() end
        flyConnection = runService.RenderStepped:Connect(flyUpdate)
        flyButton.BackgroundColor3 = Color3.fromRGB(60, 200, 100)
        flyStatus.Text = "ON"
        flyStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        flyButton.BorderColor3 = Color3.fromRGB(100, 255, 100)
    else
        humanoid.PlatformStand = false
        destroyFlyObjects()
        if flyConnection then flyConnection:Disconnect() flyConnection = nil end
        flyButton.BackgroundColor3 = Color3.fromRGB(40, 80, 120)
        flyStatus.Text = "OFF"
        flyStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        flyButton.BorderColor3 = Color3.fromRGB(255, 255, 255)
    end
end

-- ФУНКЦИИ NOCLIP (РАБОЧАЯ ВЕРСИЯ)
local function updateNoclip()
    if not noclipEnabled then return end
    
    -- Отключаем коллизии у всех частей персонажа
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") and part.CanCollide ~= false then
            part.CanCollide = false
        end
    end
end

function toggleNoclip()
    noclipEnabled = not noclipEnabled
    
    if noclipEnabled then
        -- Отключаем коллизии
        updateNoclip()
        
        -- Следим за новыми частями
        character.DescendantAdded:Connect(function(part)
            if noclipEnabled and part:IsA("BasePart") then
                part.CanCollide = false
            end
        end)
        
        -- Обновляем каждый кадр для надёжности
        if #noclipConnections == 0 then
            local conn = runService.RenderStepped:Connect(updateNoclip)
            table.insert(noclipConnections, conn)
        end
        
        noclipButton.BackgroundColor3 = Color3.fromRGB(200, 60, 100)
        noclipStatus.Text = "ON"
        noclipStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        noclipButton.BorderColor3 = Color3.fromRGB(255, 100, 100)
    else
        -- Включаем коллизии обратно
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
        
        -- Отключаем все соединения
        for _, conn in ipairs(noclipConnections) do
            conn:Disconnect()
        end
        noclipConnections = {}
        
        noclipButton.BackgroundColor3 = Color3.fromRGB(120, 40, 80)
        noclipStatus.Text = "OFF"
        noclipStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        noclipButton.BorderColor3 = Color3.fromRGB(255, 255, 255)
    end
end

