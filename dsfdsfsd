-- MM2 HUB (Ryzen Edition)
-- Интерфейс в стиле фотки (полупрозрачный фон, неоновые кнопки, вкладки)
local Library = loadstring(game:HttpGet("https://pastebin.com/raw/..."))() -- библиотека для GUI (замените на реальную)

local Window = Library:CreateWindow("Ryzen MM2", Vector2.new(100, 100), Enum.KeyCode.RightShift)

-- Вкладка MAIN
local Main = Window:CreateTab("Main")

Main:CreateToggle("Dual Gun", function(state) -- дублирует оружие
    game.Players.LocalPlayer.Character:FindFirstChild("Gun").Gun:Clone()
end)

Main:CreateToggle("Dual Knife", function(state)
    game.Players.LocalPlayer.Character:FindFirstChild("Knife"):Clone()
end)

Main:CreateToggle("Fake Bomb", function(state)
    -- спавнит фейковую бомбу с таймером (визуал)
    local bomb = Instance.new("Part")
    bomb.Size = Vector3.new(2,2,2)
    bomb.Position = game.Players.LocalPlayer.Character.HumanoidRootPart.Position + Vector3.new(0,3,0)
    bomb.BrickColor = BrickColor.Red()
    bomb.Anchored = true
    bomb.CanCollide = false
    game:GetService("Debris"):AddItem(bomb, 5)
end)

Main:CreateDropdown("Crosshair Changer", {"Dot", "Cross", "Circle"}, function(sel)
    -- меняет текстуру прицела
    game.Players.LocalPlayer.PlayerGui.Crosshair.Image = sel
end)

Main:CreateToggle("Godmode", function(state)
    game.Players.LocalPlayer.Character.Humanoid.Health = math.huge
    game.Players.LocalPlayer.Character.Humanoid.MaxHealth = math.huge
end)

Main:CreateToggle("Touch Fling", function(state)
    -- при касании кидает игроков
    local char = game.Players.LocalPlayer.Character
    char.Touched:Connect(function(hit)
        if hit.Parent and hit.Parent:FindFirstChild("Humanoid") then
            hit.Parent.HumanoidRootPart.Velocity = Vector3.new(0, 150, 0)
        end
    end)
end)

Main:CreateToggle("Anti Fling", function(state)
    game.Players.LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
end)

Main:CreateToggle("Invisible Character", function(state)
    game.Players.LocalPlayer.Character.HumanoidRootPart.Transparency = 1
end)

-- Вкладка FLING
local FlingTab = Window:CreateTab("Fling")

FlingTab:CreateButton("Fling Murderer", function()
    local murderer = getMurderer() -- функция поиска
    if murderer then murderer.HumanoidRootPart.Velocity = Vector3.new(0, 500, 0) end
end)

FlingTab:CreateButton("Fling Sheriff", function()
    local sheriff = getSheriff()
    if sheriff then sheriff.HumanoidRootPart.Velocity = Vector3.new(0, 500, 0) end
end)

local playerList = {}
FlingTab:CreateDropdown("Select Player to Fling", playerList, function(plr)
    selectedTarget = plr
end)

FlingTab:CreateButton("Refresh Player List", function()
    playerList = {}
    for _, v in pairs(game.Players:GetPlayers()) do
        table.insert(playerList, v.Name)
    end
end)

FlingTab:CreateButton("Fling Selected", function()
    if selectedTarget then
        game.Players[selectedTarget].Character.HumanoidRootPart.Velocity = Vector3.new(0, 500, 0)
    end
end)

-- Вкладка GUN
local GunTab = Window:CreateTab("Gun")

GunTab:CreateButton("Steal Gun", function()
    local gun = workspace:FindFirstChild("Gun")
    if gun then gun.Parent = game.Players.LocalPlayer.Backpack end
end)

GunTab:CreateButton("Grab Gun (auto)", function()
    while wait(0.1) do
        local gun = workspace:FindFirstChild("Gun")
        if gun then gun.Parent = game.Players.LocalPlayer.Backpack end
    end
end)

GunTab:CreateToggle("Auto Grab Gun", function(state) autoGrab = state end)

-- Вкладка KNIFE
local KnifeTab = Window:CreateTab("Knife")

KnifeTab:CreateToggle("Auto Knife Throw", function(state)
    while state and wait(0.3) do
        game:GetService("ReplicatedStorage").ThrowKnife:FireServer()
    end
end)

KnifeTab:CreateSlider("Throw Range", 10, 100, 50, function(val)
    getgenv().knifeRange = val
end)

KnifeTab:CreateToggle("Knife Aura", function(state)
    -- создаёт зону поражения
    local aura = Instance.new("Part")
aura.Size = Vector3.new(knifeRange, knifeRange, knifeRange)
    aura.Position = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
    aura.Anchored = true
    aura.CanCollide = false
    aura.Touched:Connect(function(h) 
        if h.Parent and h.Parent:FindFirstChild("Humanoid") then 
            h.Parent.Humanoid.Health = 0 
        end 
    end)
end)

-- Вкладка AIM
local AimTab = Window:CreateTab("Aim")

AimTab:CreateToggle("Silent Aim", function(state) silentAim = state end)
AimTab:CreateSlider("Prediction", 0, 100, 50, function(val) pred = val/100 end)
AimTab:CreateToggle("Wall Bang", function(state) wallBang = state end)

AimTab:CreateToggle("Auto Shoot Murder", function(state)
    while state and wait(0.5) do
        local target = getMurderer()
        if target then
            game:GetService("ReplicatedStorage").Shoot:FireServer(target.HumanoidRootPart.Position)
        end
    end
end)

AimTab:CreateSlider("Auto Shoot Delay", 0.1, 2, 0.5, function(val) shootDelay = val end)

-- Вкладка BUTTONS (плавающие кнопки)
local ButtonsTab = Window:CreateTab("Buttons")
ButtonsTab:CreateButton("Shoot Murder", function() 
    local m = getMurderer()
    if m then game:GetService("ReplicatedStorage").Shoot:FireServer(m.HumanoidRootPart.Position) end
end)
ButtonsTab:CreateButton("Throw Knife", function() game:GetService("ReplicatedStorage").ThrowKnife:FireServer() end)
ButtonsTab:CreateButton("Kill All", function()
    for _, p in pairs(game.Players:GetPlayers()) do
        if p.Character then p.Character.Humanoid.Health = 0 end
    end
end)
ButtonsTab:CreateButton("Be Invisible", function()
    game.Players.LocalPlayer.Character.HumanoidRootPart.Transparency = 1
end)
ButtonsTab:CreateButton("Camlock", function()
    -- привязывает камеру к цели
    local target = getMurderer()
    if target then workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.HumanoidRootPart.Position) end
end)
ButtonsTab:CreateButton("SPD Glitch", function() -- разгон
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 250
end)
ButtonsTab:CreateButton("Wallhop Off", function()
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = 0
end)

-- Вкладка SPEED
local SpeedTab = Window:CreateTab("Speed")
SpeedTab:CreateToggle("Speed Glitch", function(state)
    if state then
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 250
    else
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
    end
end)
SpeedTab:CreateSlider("Adjust Speed", 16, 500, 100, function(val)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = val
end)

-- Вкладка TELEPORT
local TeleTab = Window:CreateTab("Teleport")
TeleTab:CreateButton("To Map", function() game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = workspace.Map.Center end)
TeleTab:CreateButton("To Lobby", function() game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(0, 50, 0) end)
TeleTab:CreateButton("To Murderer", function() 
    local m = getMurderer()
    if m then game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = m.HumanoidRootPart.CFrame end
end)
TeleTab:CreateButton("To Sheriff", function()
    local s = getSheriff()
    if s then game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = s.HumanoidRootPart.CFrame end
end)

-- Вкладка ESP
local EspTab = Window:CreateTab("ESP")
EspTab:CreateToggle("ESP Everyone", function(state)
    for _, p in pairs(game.Players:GetPlayers()) do
        createESP(p, state)
    end
end)
EspTab:CreateToggle("Murderer Only", function(state)
    local m = getMurderer()
    if m then createESP(m, state) end
end)
EspTab:CreateToggle("Sheriff Only", function(state)
    local s = getSheriff()
    if s then createESP(s, state) end
end)
EspTab:CreateToggle("Innocent Only", function(state)
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= getMurderer() and p ~= getSheriff() then createESP(p, state) end
    end
end)
EspTab:CreateToggle("ESP Gun", function(state)
    local g = workspace:FindFirstChild("Gun")
    if g then createESP(g, state) end
end)

-- Вкладка NOTIFY
local NotifyTab = Window:CreateTab("Notify")
NotifyTab:CreateToggle("Instant Role Notify", function(state)
