-- ФУНКЦИЯ ДЛЯ ПОЛУЧЕНИЯ РОЛИ (АДАПТИВНАЯ)
local function getPlayerRole(plr)
    -- Проверяем все возможные места хранения роли
    if plr:FindFirstChild("role") then
        return plr.role.Value
    elseif plr:FindFirstChild("Role") then
        return plr.Role.Value
    elseif plr:FindFirstChild("PlayerRole") then
        return plr.PlayerRole.Value
    elseif plr:FindFirstChild("Team") then
        return plr.Team.Name
    elseif plr.Character and plr.Character:FindFirstChild("Humanoid") then
        -- Некоторые игры хранят роль в Humanoid
        local hum = plr.Character.Humanoid
        if hum:FindFirstChild("Role") then
            return hum.Role.Value
        end
    end
    return nil
end

-- ФУНКЦИЯ ПОДСВЕТКИ (ЧЕРЕЗ БИЛДЕР)
local function highlightPlayer(plr, color, duration)
    if not plr or not plr.Character then return end
    local hl = Instance.new("Highlight")
    hl.Parent = plr.Character
    hl.FillColor = color
    hl.OutlineColor = Color3.fromRGB(255,255,255)
    hl.Enabled = true
    task.delay(duration or 3, function()
        pcall(function() hl:Destroy() end)
    end)
end

-- ФУНКЦИЯ ПОИСКА ПО РОЛИ
local function findAndHighlight(roleName, color)
    local found = false
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local role = getPlayerRole(plr)
            if role and string.lower(role) == string.lower(roleName) then
                highlightPlayer(plr, color, 4)
                found = true
                print("✅ Найден "..roleName..": "..plr.Name)
            end
        end
    end
    if not found then
        print("❌ "..roleName.." не найден. Возможно, роли называются иначе.")
        print("📋 Список ролей в игре:")
        for _, plr in pairs(Players:GetPlayers()) do
            local r = getPlayerRole(plr)
            if r then
                print("   "..plr.Name.." → "..r)
            end
        end
    end
end

-- СОЗДАНИЕ КНОПОК
local function createBtn(text, y, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.85, 0, 0, 32)
    btn.Position = UDim2.new(0.075, 0, y, 0)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BackgroundColor3 = color or Color3.fromRGB(50,50,60)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = MainFrame
    btn.MouseButton1Click:Connect(callback)
    return btn
end

